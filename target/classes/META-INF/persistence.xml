<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence
                                 https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd"
             version="3.0">

    <persistence-unit name="SysCongePU" transaction-type="JTA">
        <jta-data-source>jdbc/sysconge</jta-data-source>

        <class>com.sysconge.entity.Utilisateur</class>
        <class>com.sysconge.entity.Departement</class>
        <class>com.sysconge.entity.Personnel</class>
        <class>com.sysconge.entity.TypeConge</class>
        <class>com.sysconge.entity.DemandeConge</class>
        <class>com.sysconge.entity.Approbation</class>
        <class>com.sysconge.entity.SoldeConge</class>
        <class>com.sysconge.entity.Notification</class>

        <properties>
            <property name="jakarta.persistence.schema-generation.database.action" value="create"/>
            <property name="eclipselink.logging.level" value="INFO"/>
            <property name="eclipselink.logging.level.sql" value="FINE"/>
        </properties>
    </persistence-unit>
</persistence>
